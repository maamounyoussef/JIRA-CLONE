<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Jira Clone Field Access</label>
    <description>Grants object and field access for Sprint, Subtask, ProjectMember and Ticket custom objects used by the Jira clone app.</description>

    <!-- Object permissions -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Sprint__c</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Subtask__c</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>ProjectMember__c</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Ticket__c</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Field permissions: Sprint__c -->
    <fieldPermissions>
        <field>Sprint__c.StartDate__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Sprint__c.Duration__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Sprint__c.Goal__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Sprint__c.RecordStatus__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <!-- Sprint__c.Project__c is required at field level; skip explicit FLS to avoid deploy errors -->

    <!-- Field permissions: Subtask__c -->
    <!-- Subtask__c.Ticket__c is required; skip explicit FLS -->
    <!-- Subtask__c.Summary__c is required; skip explicit FLS -->
    <fieldPermissions>
        <field>Subtask__c.StoryPoint__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Subtask__c.StartDate__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <!-- Subtask__c.EndDate__c removed (calculated) -->
    <fieldPermissions>
        <field>Subtask__c.Description__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Subtask__c.CurrentState__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Subtask__c.Assignee__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>

    <!-- Field permissions: ProjectMember__c -->
    <!-- ProjectMember__c.Project__c is required; skip explicit FLS to avoid deploy errors -->
    <fieldPermissions>
        <field>ProjectMember__c.User__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ProjectMember__c.RecordStatus__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>

    <!-- Field permissions: Ticket__c -->
    <fieldPermissions>
        <field>Ticket__c.Description__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <!-- Ticket__c.CurrentState__c is required; skip explicit FLS -->
    <fieldPermissions>
        <field>Ticket__c.Creator__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Ticket__c.AssignedTo__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Ticket__c.Epic__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Ticket__c.EndDate__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Ticket__c.Priority__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Ticket__c.Sprint__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Ticket__c.StartDate__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Ticket__c.Ticket_Type__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <!-- Ticket__c.Summary__c is required; skip explicit FLS -->
    <fieldPermissions>
        <field>Ticket__c.StoryPoint__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>

</PermissionSet>
